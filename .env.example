# Variáveis de ambiente — CRM BFF (copie para .env ou setup/local_settings.py)
# Nunca versionar valores reais de secret.

CRM_API_BASE_URL=http://localhost:8001
CRM_API_V1_STR=/api/v1
CRM_INTERNAL_API_SECRET=change-me
CRM_API_TIMEOUT=30
CRM_API_VERIFY_SSL=false
CRM_DEFAULT_LIMIT=100
CRM_ENABLE_DEBUG_LOGS=false
CRM_SERVICE_USER_ID=1
CRM_SERVICE_USERNAME=celery
