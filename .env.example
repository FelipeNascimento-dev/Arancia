# Variáveis de ambiente opcionais (copie para .env ou setup/local_settings.py)
# Nunca versionar valores reais de secret.

# CRM API (BFF Django → FastAPI)
# CRM_API_BASE_URL=http://host/api-crm
# CRM_API_V1_STR=/api/v1
# CRM_API_KEY=crm_xxxx...
# CRM_INTERNAL_API_SECRET=
# CRM_API_TIMEOUT=30
# CRM_API_VERIFY_SSL=false
# CRM_SERVICE_USERNAME=celery
# CRM_SERVICE_PASSWORD=
