# Variáveis de ambiente opcionais (copie para .env ou setup/local_settings.py)
# Nunca versionar valores reais de secret.

# CRM API (BFF Django → FastAPI)
# CRM_API_BASE_URL=http://host/api-crm
# CRM_API_V1_STR=/api/v1
# CRM_API_KEY=crm_xxxx...          # somente em modo legacy_basic
# CRM_INTERNAL_API_SECRET=          # secret compartilhado com FastAPI (scheduler + BFF Bearer)
# CRM_BFF_AUTH_MODE=bearer          # rollback: legacy_basic (equiv. handoff CRM_USE_LEGACY_BASIC_AUTH)
# CRM_USE_AGGREGATED_ENDPOINTS=true   # rollback: false → fan-out legado (~10 calls no Kanban)
# CRM_API_TIMEOUT=30
# CRM_API_VERIFY_SSL=false
# CRM_SERVICE_USERNAME=celery       # username para jobs Celery (X-Acting-User)
# CRM_SERVICE_PASSWORD=             # somente em modo legacy_basic

# Performance / cache (Fase 5–6)
# REDIS_ENABLED=true                # false em dev local → LocMem; homolog/prod: true
# PERFORMANCE_INSTRUMENTATION=false # true em dev/homolog → headers X-CRM-* no Django
# CRM_LOOKUPS_REDIS_CACHE_TTL=300
# CRM_ME_CONTEXT_REDIS_CACHE_TTL=300
# CRM_MENU_CONTEXT_CACHE_TTL=90
